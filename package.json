{
  "name": "@scalemule/chat",
  "version": "0.0.12",
  "description": "ScaleMule standalone chat SDK — real-time messaging, presence, typing indicators",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./element": {
      "types": "./dist/element.d.ts",
      "import": "./dist/element.js",
      "require": "./dist/element.cjs"
    },
    "./iframe": {
      "types": "./dist/iframe.d.ts",
      "import": "./dist/iframe.js",
      "require": "./dist/iframe.cjs"
    }
  },
  "files": [
    "dist",
    "docs",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup && npm run build:types && npm run check:budgets",
    "build:types": "tsc --emitDeclarationOnly --project tsconfig.json",
    "check:budgets": "node ./scripts/check-bundle-budgets.mjs",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0",
    "livekit-client": ">=2.0.0",
    "@livekit/components-react": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "livekit-client": {
      "optional": true
    },
    "@livekit/components-react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@livekit/components-react": "^2.9.20",
    "@livekit/components-styles": "^1.2.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "jsdom": "^26.0.0",
    "livekit-client": "^2.18.1",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "author": "ScaleMule Inc. <support@scalemule.com>",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
