{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM"],
    "allowSyntheticDefaultImports": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@scalemule/chat": ["./src/index.ts"],
      "@scalemule/chat/react": ["./src/react.tsx"],
      "@scalemule/chat/react/admin": ["./src/react-admin.ts"],
      "@scalemule/chat/themes/tailwind": ["./src/themes/tailwind.ts"],
      "@scalemule/chat/themes/shadcn": ["./src/themes/shadcn.ts"]
    }
  },
  "include": [
    "examples/01-support-widget/index.ts",
    "examples/02-channels-app/App.tsx",
    "examples/03-rep-dashboard/App.tsx"
  ],
  "exclude": ["node_modules", "dist", "src/**/__tests__/**"]
}
